# ── Database ──────────────────────────────────────────────────────────────────
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=EcommerceDb;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=True;MultipleActiveResultSets=True

# ── JWT ───────────────────────────────────────────────────────────────────────
Jwt__Secret=ThisIsAVeryStrongSecretKeyForJwtThatIsAtLeast32Chars!
Jwt__Issuer=EcommerceApp
Jwt__Audience=EcommerceApp
Jwt__AccessTokenExpiryMinutes=15
Jwt__RefreshTokenExpiryDays=7
Jwt__PasswordResetTokenExpiryMinutes=10

# ── CORS ──────────────────────────────────────────────────────────────────────
Cors__AllowedOrigins=http://localhost:5173,https://yourdomain.com

# ── Provider switches (values: SendGrid | Smtp | Mailjet | Log) ──────────────
NotificationProvider__Email=Log
NotificationProvider__Sms=Log
NotificationProvider__SearchEngine=Sql

# ── SendGrid ──────────────────────────────────────────────────────────────────
SendGrid__ApiKey=REPLACE_WITH_SENDGRID_API_KEY
SendGrid__FromEmail=noreply@yourdomain.com
SendGrid__FromName=EcommerceApp

# ── SMTP (MailKit / Gmail App Password) ──────────────────────────────────────
Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__Username=your-gmail@gmail.com
Smtp__Password=your-gmail-app-password
Smtp__FromEmail=your-gmail@gmail.com
Smtp__FromName=EcommerceApp
Smtp__EnableSsl=true

# ── Mailjet ───────────────────────────────────────────────────────────────────
Mailjet__ApiKey=REPLACE_WITH_MAILJET_API_KEY
Mailjet__SecretKey=REPLACE_WITH_MAILJET_SECRET_KEY
Mailjet__FromEmail=noreply@yourdomain.com
Mailjet__FromName=EcommerceApp

# ── Twilio ────────────────────────────────────────────────────────────────────
Twilio__AccountSid=REPLACE_WITH_TWILIO_ACCOUNT_SID
Twilio__AuthToken=REPLACE_WITH_TWILIO_AUTH_TOKEN
Twilio__FromPhoneNumber=+1XXXXXXXXXX

# ── Fast2SMS ──────────────────────────────────────────────────────────────────
Fast2Sms__ApiKey=REPLACE_WITH_FAST2SMS_API_KEY
Fast2Sms__SenderId=FSTSMS
Fast2Sms__MessageType=T

# ── Elasticsearch ─────────────────────────────────────────────────────────────
Elasticsearch__Uri=http://localhost:9200
Elasticsearch__Username=
Elasticsearch__Password=
Elasticsearch__ProductIndexName=products

# ── Stripe ────────────────────────────────────────────────────────────────────
Stripe__PublishableKey=pk_test_REPLACE_WITH_STRIPE_PUBLISHABLE_KEY
Stripe__SecretKey=sk_test_REPLACE_WITH_STRIPE_SECRET_KEY
Stripe__WebhookSecret=whsec_REPLACE_WITH_STRIPE_WEBHOOK_SECRET
Stripe__Currency=usd
Stripe__SuccessUrl=http://localhost:5173/order-confirmation?session_id={CHECKOUT_SESSION_ID}
Stripe__CancelUrl=http://localhost:5173/checkout

# ── Rate limiting ─────────────────────────────────────────────────────────────
RateLimit__OtpMaxSendPer15Min=5
RateLimit__OtpMaxFailedAttempts=5
RateLimit__OtpBlockDurationMinutes=30
RateLimit__LoginMaxPer5Min=10
RateLimit__GeneralUnauthPerMin=100
RateLimit__GeneralAuthPerMin=500
RateLimit__SearchTokensPerMin=100

# ── Serilog ───────────────────────────────────────────────────────────────────
Serilog__MinimumLevel__Default=Information
Serilog__MinimumLevel__Override__Microsoft=Warning
Serilog__MinimumLevel__Override__System=Warning
Serilog__LogFilePath=logs/ecommerce-.log

# ── QuestPDF ──────────────────────────────────────────────────────────────────
QuestPDF__LicenseType=Community

# ── Application ───────────────────────────────────────────────────────────────
App__DevMode=true
App__ApiBaseUrl=https://localhost:7001
App__MaxAddressesPerUser=5
App__OrderCancelWindowHours=24
App__ReturnWindowDays=7
App__CartIdleReminderDays=7
App__StockReservationExpiryMinutes=15